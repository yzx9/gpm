*.njsproj
*.sln
*.sw?

# nix
.direnv/

# rust
target/

# tauri
# Ignore auto-generated schemas
src-tauri/gen/schemas/
# Ignore auto-generated plugin permissions
tauri-plugin-*/permissions/autogenerated/
tauri-plugin-*/permissions/schemas/
# Ignore Tauri icons — regenerated by `tauri icon` on build
src-tauri/icons/
# Web favicons — regenerated from assets/app-icon.png by scripts/gen-icons.sh
public/icon-*.png
src-tauri/gen/android/app/src/main/res/mipmap-*/
src-tauri/gen/android/app/src/main/res/values/ic_launcher_background.xml
# Ignore Android build outputs but keep the scaffolded project
src-tauri/gen/android/.gradle/
src-tauri/gen/android/app/build/
src-tauri/gen/android/app/tauri.build.gradle.kts
src-tauri/gen/android/build/
# Ignore build/IDE outputs in local plugin android modules (tauri-plugin-*/android/)
tauri-plugin-*/android/.tauri/
tauri-plugin-*/android/.gradle/
tauri-plugin-*/android/build/
tauri-plugin-*/android/.cxx/
tauri-plugin-*/android/captures/
tauri-plugin-*/android/local.properties
tauri-plugin-*/android/**/*.iml

# Android signing
*.jks
*.keystore
src-tauri/gen/android/.keystores/
src-tauri/gen/android/keystore.properties

# agentic tools
.claude/worktrees/
.gstack/
.playwright-mcp/
