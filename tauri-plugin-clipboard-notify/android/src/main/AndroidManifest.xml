<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Android 13+ runtime permission for posting notifications. Pre-33
         devices grant this at install time. The AGP manifest merger folds
         this into the app manifest; no app-manifest edit needed. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!-- Manifest-declared, non-exported receiver for the notification's
             body-tap. Only our own PendingIntent (explicit intent) can reach
             it; survives process death so the tap still clears after a kill.
             Merged into the app manifest by AGP. -->
        <receiver
            android:name="xyz.yzx9.gpm.clipboardnotify.ClipboardClearReceiver"
            android:exported="false" />
    </application>
</manifest>
